{
  "$schema": "../node_modules/@tauri-apps/cli/schema/capabilities.json",
  "identifier": "default",
  "description": "Default capabilities for Moses desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "shell:allow-open",
    "dialog:allow-open",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:scope-home-recursive",
    "fs:scope-document-recursive",
    "fs:scope-desktop-recursive"
  ]
}
